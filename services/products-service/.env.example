# =============================================================================
# Variables de entorno — products-service
# =============================================================================
# cp .env.example .env.local    # Desarrollo local (npm run dev)
# cp .env.example .env.docker   # Contenedor vía docker compose
# =============================================================================

PORT=3002

# PostgreSQL — products-db
DB_USER=
DB_PASSWORD=
DB_NAME=kiora_products

# --- .env.local (desarrollo en el host) ---
# DB_HOST=localhost
# DB_PORT=5434       # Puerto externo del contenedor products-db en Docker Compose
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5434/kiora_products

# --- .env.docker (dentro de Compose) ---
# DB_HOST=products-db
# DB_PORT=5432
# DATABASE_URL=postgres://USER:PASSWORD@products-db:5432/kiora_products

CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REDIS_HOST=localhost
REDIS_PORT=6379