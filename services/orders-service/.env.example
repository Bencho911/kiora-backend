# =============================================================================
# Variables de entorno — orders-service
# =============================================================================
# cp .env.example .env.local    # Desarrollo local (npm run dev)
# cp .env.example .env.docker   # Contenedor vía docker compose
# =============================================================================

PORT=3004

# PostgreSQL — orders-db
DB_USER=
DB_PASSWORD=
DB_NAME=kiora_orders

# --- .env.local (desarrollo en el host) ---
# DB_HOST=localhost
# DB_PORT=5436       # Puerto externo del contenedor orders-db en Docker Compose
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5436/kiora_orders

# --- .env.docker (dentro de Compose) ---
# DB_HOST=orders-db
# DB_PORT=5432
# DATABASE_URL=postgres://USER:PASSWORD@orders-db:5432/kiora_orders

# URLs de otros servicios (comunicación HTTP inter-servicio)
USERS_SERVICE_URL=http://users-service:3001
INVENTORY_SERVICE_URL=http://inventory-service:3003

CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

STRIPE_SECRET_KEY=sk_test_reemplazar_con_tu_llave_de_stripe
STRIPE_WEBHOOK_SECRET=whsec_reemplazar_con_tu_webhook_secret
