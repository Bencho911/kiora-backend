# =============================================================================
# Variables de entorno — notifications-service
# =============================================================================
# cp .env.example .env.local    # Desarrollo local (npm run dev)
# cp .env.example .env.docker   # Contenedor vía docker compose
# =============================================================================

PORT=3005

# Redis — pub/sub para recibir eventos de notificación
# El mismo Redis que usa users-service para la blacklist JWT
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Canal Redis donde se publican eventos de notificación
# Publicar un mensaje con: { type, to, subject, body }
REDIS_NOTIFICATIONS_CHANNEL=kiora:notifications

# SMTP — Nodemailer
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true si tu SMTP usa SSL en el puerto (ej. 465)
SMTP_SECURE=false
FROM_EMAIL=no-reply@kiora.com

NODE_ENV=development
