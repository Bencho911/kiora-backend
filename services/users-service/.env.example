# =============================================================================
# Variables de entorno — users-service
# =============================================================================
# No uses un único ".env" mezclando Docker y local: genera dos archivos.
#
#   cp .env.example .env.local    # Node en tu máquina (npm run dev)
#   cp .env.example .env.docker     # Contenedor vía docker compose
#
# La app carga en este orden: ENV_FILE → .env.local → .env (solo fallback).
# Migraciones: npm run migrate:up (.env.local) | npm run migrate:up:docker
# =============================================================================

PORT=3001

# PostgreSQL
DB_USER=
DB_PASSWORD=
DB_NAME=kiora_users

# --- .env.local (desarrollo en el host) ---
# DB_HOST=localhost
# DB_PORT=5433       # Puerto externo del contenedor users-db en Docker Compose
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5433/kiora_users

# --- .env.docker (servicio users-service dentro de Compose) ---
# DB_HOST=users-db
# DB_PORT=5432
# DATABASE_URL=postgres://USER:PASSWORD@users-db:5432/kiora_users

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Redis (blacklist JWT). En Compose: REDIS_HOST=kiora-redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Blacklist: si Redis falla, false = no aceptar requests que dependan de revocación (503).
# En producción recomendado: BLACKLIST_FAIL_OPEN=false
BLACKLIST_FAIL_OPEN=false

# Email (SMTP) — recuperación de contraseña OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Si tu SMTP usa SSL (por ejemplo 465), pon true
SMTP_SECURE=false
FROM_EMAIL=no-reply@tudominio.com
APP_URL=http://localhost:3000

CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
