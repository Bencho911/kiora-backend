# =============================================================================
# Variables de entorno — inventory-service
# =============================================================================
# cp .env.example .env.local    # Desarrollo local (npm run dev)
# cp .env.example .env.docker   # Contenedor vía docker compose
# =============================================================================

PORT=3003

# PostgreSQL — inventory-db
DB_USER=
DB_PASSWORD=
DB_NAME=kiora_inventory

# --- .env.local (desarrollo en el host) ---
# DB_HOST=localhost
# DB_PORT=5435       # Puerto externo del contenedor inventory-db en Docker Compose
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5435/kiora_inventory

# --- .env.docker (dentro de Compose) ---
# DB_HOST=inventory-db
# DB_PORT=5432
# DATABASE_URL=postgres://USER:PASSWORD@inventory-db:5432/kiora_inventory

# URL del products-service (para validar que un producto existe)
PRODUCTS_SERVICE_URL=http://products-service:3002

CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
REDIS_HOST=localhost
REDIS_PORT=6379
