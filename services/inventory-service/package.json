{
  "name": "inventory-service",
  "version": "1.0.0",
  "description": "Microservicio de inventario y proveedores — Kiora",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --runInBand",
    "audit:ci": "npm audit --audit-level=high",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "migrate:up": "node-pg-migrate up --envPath .env.local --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --envPath .env.local --migrations-dir src/db/migrations",
    "migrate:up:docker": "node-pg-migrate up --envPath .env.docker --migrations-dir src/db/migrations",
    "migrate:down:docker": "node-pg-migrate down --envPath .env.docker --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --envPath .env.local --migrations-dir src/db/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.0.2",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.5",
    "opossum": "^9.0.0",
    "pg": "^8.19.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
